{
  "name": "zoomcast",
  "version": "1.0.0",
  "description": "Screen recorder with automatic zoom effects at click positions",
  "main": "src/main/index.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:renderer\" \"npm run dev:electron\"",
    "dev:renderer": "vite",
    "dev:electron": "node scripts/start-electron.js",
    "build": "vite build && electron-builder",
    "build:pack": "vite build && electron-builder --dir",
    "build:inno": "npm run build:pack && node scripts/build-inno.js",
    "preview": "vite preview"
  },
  "keywords": [],
  "author": "dodo-cb",
  "license": "ISC",
  "devDependencies": {
    "@vitejs/plugin-react": "^6.0.2",
    "concurrently": "^9.2.1",
    "electron": "^42.4.0",
    "electron-builder": "^26.15.3",
    "vite": "^8.0.16",
    "wait-on": "^8.0.5"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.3.1",
    "ffmpeg-static": "^5.3.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwindcss": "^4.3.1",
    "three": "^0.184.0",
    "uiohook-napi": "^1.5.5"
  },
  "build": {
    "appId": "com.dodo.zoomcast",
    "productName": "ZoomCast",
    "copyright": "© 2026 ZoomCast",
    "win": {
      "target": [{ "target": "nsis", "arch": ["x64"] }]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "ZoomCast",
      "installerHeaderIcon": "assets/icon.ico",
      "deleteAppDataOnUninstall": false
    },
    "files": [
      "src/main/**/*",
      "src/processor/**/*",
      "dist/**/*"
    ],
    "directories": {
      "buildResources": "assets",
      "output": "release"
    }
  }
}
